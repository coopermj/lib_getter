<!DOCTYPE html>
<html lang="en">
<head>
  <title>lib_getter</title>
  <%- include('_head') %>
  <style>
    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .login-box {
      width: 100%;
      max-width: 340px;
    }
    .login-logo {
      font-family: 'Playfair Display', Georgia, serif;
      font-weight: 500;
      font-size: 28px;
      color: var(--gold);
      letter-spacing: .01em;
      margin-bottom: 32px;
      display: block;
    }
    .login-box .btn-primary {
      width: 100%;
      padding: 11px 18px;
      font-size: 14px;
      margin-top: 4px;
    }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-box">
      <span class="login-logo">lib_getter</span>
      <% if (error) { %>
        <p class="error-msg"><%= error %></p>
      <% } %>
      <form action="/login" method="POST">
        <div class="field">
          <label>Password</label>
          <input type="password" name="password" autofocus autocomplete="current-password">
        </div>
        <button type="submit" class="btn btn-primary">Continue</button>
      </form>
    </div>
  </div>
</body>
</html>
