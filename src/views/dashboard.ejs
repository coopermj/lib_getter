<!DOCTYPE html>
<html lang="en">
<head>
  <title>lib_getter</title>
  <%- include('_head') %>
</head>
<body>
  <%- include('_nav') %>
  <main class="page">

    <div class="page-header">
      <h1 class="page-title">Wishlist</h1>
      <form action="/books/scan-all" method="POST">
        <button type="submit" class="btn btn-ghost">Scan all</button>
      </form>
    </div>

    <!-- Add book -->
    <form action="/books" method="POST" class="add-row">
      <input type="text" name="query"
        placeholder="Title, keywords, Amazon or Goodreads URL"
        required>
      <button type="submit" class="btn btn-primary">Add</button>
    </form>

    <!-- Book list -->
    <% if (books.length === 0) { %>
      <p class="empty-state">No books yet. Add one above.</p>
    <% } %>

    <% books.forEach(book => { %>
      <div class="book-card" id="book-<%= book.id %>">
        <div class="book-card-header">
          <div>
            <p class="book-title"><%= book.label %></p>
            <% if (book.last_scanned_at) { %>
              <p class="book-scanned">
                Scanned <%= new Date(book.last_scanned_at).toLocaleString() %>
              </p>
            <% } %>
          </div>
          <div class="book-actions">
            <button class="btn btn-scan" onclick="scanBook(<%= book.id %>, this)">
              Scan
            </button>
            <form action="/books/<%= book.id %>/delete" method="POST" style="margin:0;">
              <button type="submit" class="btn-danger">×</button>
            </form>
          </div>
        </div>
        <div id="results-<%= book.id %>"></div>
      </div>
    <% }) %>

  </main>

  <script>
    async function scanBook(id, btn) {
      const card      = document.getElementById('book-' + id);
      const resultsEl = document.getElementById('results-' + id);
      btn.disabled    = true;
      btn.textContent = 'Scanning…';
      resultsEl.innerHTML = '<div class="book-results"><span class="scanning">Scanning libraries…</span></div>';
      try {
        const res  = await fetch('/books/' + id + '/scan', { method: 'POST' });
        const html = await res.text();
        resultsEl.innerHTML = html;
        // light up the accent bar if any result is available
        if (resultsEl.querySelector('.badge-available')) {
          card.classList.add('has-available');
        } else {
          card.classList.remove('has-available');
        }
      } catch (e) {
        resultsEl.innerHTML =
          '<div class="book-results"><span class="badge-error">Request failed: ' + e.message + '</span></div>';
      } finally {
        btn.disabled    = false;
        btn.textContent = 'Scan';
      }
    }
  </script>
</body>
</html>
